---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'x402 micropayments, live. Buy a compliance report for $0.001 testnet USDC, signed by a Coinbase Smart Wallet and settled on Base Sepolia via the Coinbase CDP x402 facilitator.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>
  <div class="page-container">
    <!-- Header -->
    <header class="site-header">
      <a href="/" class="logo">stable<span>402</span>.com</a>
      <nav>
        <a href="/">Demo</a>
        <a href="/about">About</a>
        <span class="build-badge">
          <span class="build-badge-dot" aria-hidden="true"></span>
          Building in public &middot; April 2026
        </span>
      </nav>
    </header>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <p><a href="mailto:leo@stableclarity.com" class="site-footer__email">leo@stableclarity.com</a></p>
    </footer>
  </div>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
