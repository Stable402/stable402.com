          <rect x="380" y="160" width="160" height="140" rx="6" fill="#fffbeb" stroke="#f59e0b" stroke-dasharray="3,3" />
          <text x="460" y="180" text-anchor="middle" font-weight="700" fill="#b45309" font-size="10">REGULATORY QUESTION</text>
          <text x="460" y="200" text-anchor="middle" fill="#1a1a1a" font-size="11">Recordkeeping</text>
          <text x="460" y="216" text-anchor="middle" fill="#1a1a1a" font-size="11">and revenue?</text>
          <text x="460" y="240" text-anchor="middle" fill="#475569" font-size="10">Travel Rule</text>
          <text x="460" y="256" text-anchor="middle" fill="#475569" font-size="10">aggregate flow</text>
          <text x="460" y="282" text-anchor="middle" fill="#0f172a" font-size="10" font-style="italic">Provider-side ledger</text>

          <rect x="560" y="160" width="180" height="140" rx="6" fill="#fef2f2" stroke="#ef4444" stroke-dasharray="3,3" />
          <text x="650" y="180" text-anchor="middle" font-weight="700" fill="#b91c1c" font-size="10">REGULATORY QUESTION</text>
          <text x="650" y="200" text-anchor="middle" fill="#1a1a1a" font-size="11">Who is the MSB</text>
          <text x="650" y="216" text-anchor="middle" fill="#1a1a1a" font-size="11">on the fiat leg?</text>
          <text x="650" y="240" text-anchor="middle" fill="#475569" font-size="10">FinCEN MSB</text>
          <text x="650" y="256" text-anchor="middle" fill="#475569" font-size="10">jurisdictional</text>
          <text x="650" y="282" text-anchor="middle" fill="#0f172a" font-size="10" font-style="italic">Bridge · BVNK · Paxos</text>

