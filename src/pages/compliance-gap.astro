           aria-label="Four-leg agent-payments flow with the regulatory question at each leg.">
        <defs>
          <marker id="cgarr" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M0,0 L10,5 L0,10 z" fill="#475569" />
          </marker>
        </defs>

        <g font-family="var(--font-sans, system-ui)" font-size="11">
          <!-- Leg 1: Agent wallet -->
          <rect x="20" y="40" width="160" height="80" rx="6" fill="#fff" stroke="#0f172a" stroke-width="1.5" />
          <text x="100" y="66" text-anchor="middle" font-weight="700" fill="#0f172a">Leg 1</text>
          <text x="100" y="84" text-anchor="middle" fill="#1a1a1a">Agent wallet</text>
          <text x="100" y="102" text-anchor="middle" fill="#475569" font-size="10">EVM · Solana · A2A</text>

          <!-- Leg 2: Facilitator -->
          <rect x="200" y="40" width="160" height="80" rx="6" fill="#fff" stroke="#0f172a" stroke-width="1.5" />
          <text x="280" y="66" text-anchor="middle" font-weight="700" fill="#0f172a">Leg 2</text>
          <text x="280" y="84" text-anchor="middle" fill="#1a1a1a">Facilitator</text>
          <text x="280" y="102" text-anchor="middle" fill="#475569" font-size="10">CDP · pay.sh · Cloudflare</text>

          <!-- Leg 3: API provider -->
          <rect x="380" y="40" width="160" height="80" rx="6" fill="#fff" stroke="#0f172a" stroke-width="1.5" />
          <text x="460" y="66" text-anchor="middle" font-weight="700" fill="#0f172a">Leg 3</text>
          <text x="460" y="84" text-anchor="middle" fill="#1a1a1a">API provider</text>
          <text x="460" y="102" text-anchor="middle" fill="#475569" font-size="10">Resource · revenue</text>

          <!-- Leg 4: Fiat-out -->
          <rect x="560" y="40" width="180" height="80" rx="6" fill="#fff" stroke="#0f172a" stroke-width="1.5" />
          <text x="650" y="66" text-anchor="middle" font-weight="700" fill="#0f172a">Leg 4</text>
          <text x="650" y="84" text-anchor="middle" fill="#1a1a1a">Fiat-out leg</text>
          <text x="650" y="102" text-anchor="middle" fill="#475569" font-size="10">MSB · off-ramp</text>

          <!-- Arrows between -->
          <line x1="180" y1="80" x2="200" y2="80" stroke="#475569" stroke-width="1.4" marker-end="url(#cgarr)" />
          <line x1="360" y1="80" x2="380" y2="80" stroke="#475569" stroke-width="1.4" marker-end="url(#cgarr)" />
          <line x1="540" y1="80" x2="560" y2="80" stroke="#475569" stroke-width="1.4" marker-end="url(#cgarr)" />

          <!-- Question boxes below each leg -->
          <rect x="20" y="160" width="160" height="140" rx="6" fill="#fffbeb" stroke="#f59e0b" stroke-dasharray="3,3" />
          <text x="100" y="180" text-anchor="middle" font-weight="700" fill="#b45309" font-size="10">REGULATORY QUESTION</text>
          <text x="100" y="200" text-anchor="middle" fill="#1a1a1a" font-size="11">Is this wallet</text>
          <text x="100" y="216" text-anchor="middle" fill="#1a1a1a" font-size="11">sanctioned?</text>
          <text x="100" y="240" text-anchor="middle" fill="#475569" font-size="10">OFAC screen</text>
