---
// GateDemo.astro — Live interactive demo for POC 1
// Calls api.stable402.com/gate and decodes the PAYMENT-REQUIRED header client-side
---

<div class="gate-demo">
  <button id="callGate" class="demo-btn">
    Send request → api.stable402.com/gate
  </button>

  <div id="demoResult" class="demo-result" hidden>
    <div class="result-row">
      <span class="result-label">Status</span>
      <span id="demoStatus" class="result-value mono"></span>
    </div>
    <div class="result-row">
      <span class="result-label">PAYMENT-REQUIRED (decoded)</span>
      <pre id="demoPayload"><code></code></pre>
    </div>
    <div class="result-row">
      <span class="result-label">curl equivalent</span>
      <pre><code>curl -i https://api.stable402.com/gate</code></pre>
    </div>
  </div>

  <div id="demoError" class="demo-error" hidden></div>
</div>

<script>
  const btn = document.getElementById('callGate') as HTMLButtonElement;
  const result = document.getElementById('demoResult') as HTMLDivElement;
  const error = document.getElementById('demoError') as HTMLDivElement;
  const statusEl = document.getElementById('demoStatus') as HTMLSpanElement;
  const payloadEl = document.querySelector('#demoPayload code') as HTMLElement;

  btn.addEventListener('click', async () => {
    btn.textContent = 'Sending…';
    btn.disabled = true;
    result.hidden = true;
    error.hidden = true;

    try {
      const res = await fetch('https://api.stable402.com/gate');
      const header = res.headers.get('PAYMENT-REQUIRED');

      statusEl.textContent = `HTTP ${res.status} ${res.statusText || 'Payment Required'}`;

      if (header) {
        try {
          const decoded = JSON.parse(atob(header));
          payloadEl.textContent = JSON.stringify(decoded, null, 2);
        } catch {
          payloadEl.textContent = header;
        }
      } else {
        payloadEl.textContent = '(no PAYMENT-REQUIRED header)';
      }

      result.hidden = false;
    } catch (err) {
      error.textContent = `Request failed: ${err instanceof Error ? err.message : String(err)}`;
      error.hidden = false;
    } finally {
      btn.textContent = 'Send request → api.stable402.com/gate';
      btn.disabled = false;
    }
  });
</script>

<style>
  .gate-demo {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .demo-btn {
    display: inline-flex;
    align-items: center;
    font-family: var(--sl-font-mono);
    font-size: 0.875rem;
    font-weight: 600;
    color: #0a0e17;
    background: var(--sl-color-accent);
    border: none;
    border-radius: 6px;
    padding: 0.625rem 1.25rem;
    cursor: pointer;
    transition: opacity 0.15s ease;
    align-self: flex-start;
  }

  .demo-btn:hover:not(:disabled) {
    opacity: 0.9;
  }

  .demo-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .demo-result {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    overflow: hidden;
    background: var(--sl-color-bg-nav);
  }

  .result-row {
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid var(--sl-color-gray-6);
  }

  .result-row:last-child {
    border-bottom: none;
  }

  .result-label {
    display: block;
    font-size: 0.7rem;
    font-family: var(--sl-font-mono);
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }

  .result-value {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--sl-color-accent);
  }

  .result-row pre {
    margin: 0;
    background: transparent;
    border: none;
    padding: 0;
  }

  .demo-error {
    font-family: var(--sl-font-mono);
    font-size: 0.875rem;
    color: #f87171;
    background: rgba(248, 113, 113, 0.1);
    border: 1px solid rgba(248, 113, 113, 0.25);
    border-radius: 6px;
    padding: 0.875rem 1rem;
  }
</style>
